# Copier en .env (lu automatiquement par docker compose) et renseigner.
# Ces variables sont utilisées CÔTÉ SERVEUR. Jamais exposées au navigateur.

# --- Serveur d'inférence (proxy Next /api/chat) ---
# URL du serveur d'inférence, vue depuis le conteneur.
INFERENCE_BASE_URL=http://host.docker.internal:11434
# Clé d'API envoyée en header X-API-Key (clé de l'équipe DEV WEB).
INFERENCE_API_KEY=remplace-par-ta-cle

# --- Authentification ---
# Secret de signature des sessions (OBLIGATOIRE). Génère-le avec :
#   openssl rand -hex 32
AUTH_SECRET=remplace-par-un-secret-aleatoire-long
# Mettre "true" uniquement si tu sers l'app en HTTPS.
COOKIE_SECURE=false
